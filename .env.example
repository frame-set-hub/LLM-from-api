# ==============================================================================
#  LLM Chat Client — Environment Configuration EXAMPLE
#  Copy this file → .env and fill in real values.
# ==============================================================================

# --- Gateway ---
ANTHROPIC_BASE_URL=https://llm-gateway.float16.cloud/

# --- Auth ---
ANTHROPIC_AUTH_TOKEN=your-api-key-here

# --- Model aliases ---
ANTHROPIC_DEFAULT_SONNET_MODEL=Qwen3.5-122B-A10B
ANTHROPIC_DEFAULT_HAIKU_MODEL=Qwen3.5-122B-A10B
ANTHROPIC_DEFAULT_OPUS_MODEL=Qwen3.5-122B-A10B

# --- Misc flags ---
CLAUDE_CODE_USE_BEDROCK=0
MAX_THINKING_TOKENS=0

# --- Active model used by this chat client ---
LLM_MODEL=Qwen3.5-122B-A10B
